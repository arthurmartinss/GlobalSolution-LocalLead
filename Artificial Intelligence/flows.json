    {
        "id": "216435a8eff735c9",
        "type": "function",
        "z": "668853a60b4694c8",
        "name": "procOut Text and Opt",
        "func": "const generic = msg.payload.output.generic || [];\n\nlet buttons = [];\nlet textParts = [];\nlet opcoesFaladas = [];\n\ngeneric.forEach(item => {\n    if (item.response_type === \"text\" && item.text) {\n        textParts.push(item.text);\n    }\n\n    if (item.response_type === \"option\" && item.options) {\n        if (item.title) {\n            textParts.push(item.title);\n        }\n\n        item.options.forEach((opt, index) => {\n            const numero = index + 1;\n            const label = opt.label;\n\n            opcoesFaladas.push(`Opção ${numero}: ${label}`);\n\n            buttons.push([{\n                text: label,\n                callback_data: opt.value?.input?.text || label\n            }]);\n        });\n    }\n});\n\n// texto original do Watson para aparecer no Telegram\nmsg.textPartsOriginal = textParts.join(\"\\n\");\n\n// texto com opções para o TTS\nmsg.textoParaFalar = [\n    ...textParts,\n    ...opcoesFaladas\n].join(\". \");\n\n// botões\nmsg.botoesTelegram = buttons;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 900,
        "y": 320,
        "wires": [
            [
                "c63da4b14df57981",
                "b88feb8986b45a50"
            ]
        ]
