        "id": "b88feb8986b45a50",
        "type": "function",
        "z": "668853a60b4694c8",
        "name": "procOut Opt",
        "func": "if (!msg.botoesTelegram || msg.botoesTelegram.length === 0) {\n \n    msg.payload = {\n        chatId: msg.chatId,\n        type: \"message\",\n        content: msg.textPartsOriginal || \"Mensagem vazia\"\n    };\n \n    return msg;\n}\n \nmsg.payload = {\n    chatId: msg.chatId,\n    type: \"message\",\n    content: msg.textPartsOriginal || \"Escolha uma opção:\",\n    options: {\n        reply_markup: JSON.stringify({\n            inline_keyboard: msg.botoesTelegram\n        })\n    }\n};\n \nreturn msg;",
